#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd)"
WRAPPER_PATH="$PROJECT_ROOT/bin/cursor-agent-proxy"

BEGIN_MARK="# >>> cursor-agent-proxy >>>"
END_MARK="# <<< cursor-agent-proxy <<<"

if [ ! -x "$WRAPPER_PATH" ]; then
  echo "cursor-agent-proxy: wrapper not found or not executable: $WRAPPER_PATH" >&2
  exit 1
fi

resolve_rc_file() {
  if [ -n "${CURSOR_AGENT_PROXY_RC:-}" ]; then
    printf '%s\n' "$CURSOR_AGENT_PROXY_RC"
    return
  fi
  case "$(basename "${SHELL:-}")" in
    zsh)
      printf '%s\n' "$HOME/.zshrc"
      ;;
    bash)
      if [ -f "$HOME/.bashrc" ]; then
        printf '%s\n' "$HOME/.bashrc"
      else
        printf '%s\n' "$HOME/.bash_profile"
      fi
      ;;
    *)
      if [ -f "$HOME/.zshrc" ]; then
        printf '%s\n' "$HOME/.zshrc"
      elif [ -f "$HOME/.bashrc" ]; then
        printf '%s\n' "$HOME/.bashrc"
      else
        printf '%s\n' "$HOME/.profile"
      fi
      ;;
  esac
}

RC_FILE="$(resolve_rc_file)"
mkdir -p "$(dirname "$RC_FILE")"
touch "$RC_FILE"

# Aliases are used instead of replacing the ~/.local/bin symlinks because the
# Cursor Agent self-update does `rm -f` + recreates ~/.local/bin/{agent,
# cursor-agent} on every upgrade, which would clobber a symlink install. A shell
# rc entry is never touched by the updater, and the wrapper still auto-follows
# the latest version under ~/.local/share/cursor-agent/versions.
block="$(cat <<EOF
$BEGIN_MARK
# Managed by cursor-agent-proxy/scripts/install-local. Re-run it to update paths.
alias cursor-agent='$WRAPPER_PATH'
alias agent='$WRAPPER_PATH'
$END_MARK
EOF
)"

tmp="$(mktemp)"
# Drop any previously managed block so re-running updates in place.
awk -v b="$BEGIN_MARK" -v e="$END_MARK" '
  $0==b {inblk=1; next}
  $0==e {inblk=0; next}
  !inblk {print}
' "$RC_FILE" >"$tmp"

{
  # Trim trailing blank lines, then re-append with a single separating newline so
  # repeated installs stay idempotent instead of piling up blank lines.
  awk 'NF{last=NR} {line[NR]=$0} END{for (i=1; i<=last; i++) print line[i]}' "$tmp"
  printf '\n%s\n' "$block"
} >"$RC_FILE"
rm -f "$tmp"

echo "Installed cursor-agent proxy aliases into: $RC_FILE"
echo "  cursor-agent -> $WRAPPER_PATH"
echo "  agent        -> $WRAPPER_PATH"
echo
echo "Apply now (or open a new terminal):"
echo "  source \"$RC_FILE\""
