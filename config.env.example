# Copy to config.env and adjust for your network.
CURSOR_AGENT_PROXY=http://proxy.example:8080
CURSOR_AGENT_NO_PROXY=127.0.0.1,localhost

# Optional: where official cursor-agent versions are installed.
# The wrapper uses the latest executable under this directory by default.
# CURSOR_AGENT_VERSIONS_DIR=/root/.local/share/cursor-agent/versions

# Optional: pin a specific cursor-agent binary. This disables latest-version auto-discovery.
# CURSOR_AGENT_BIN=/root/.local/share/cursor-agent/versions/2026.06.04-5fd875e/cursor-agent

# Written by scripts/install-local for rollback only.
# ORIGINAL_CURSOR_AGENT_BIN=/root/.local/share/cursor-agent/versions/2026.06.04-5fd875e/cursor-agent

# Optional: disable the HTTP/2 CONNECT shim while keeping normal proxy env.
# CURSOR_AGENT_HTTP2_PROXY=0
